# Notion API Token (從 https://www.notion.so/my-integrations 取得)
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxx

# Notion Database ID (從網址列取得，為 32 字元的字串)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM (預設使用 Gemini)
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=gemini-2.5-flash

# Telegram Bot Token (從 @BotFather 取得)
TG_BOT_TOKEN=1234567890:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Channel/Group ID (例如 -1001234567890，若是頻道記得前面要加 -100)
TG_CHANNEL_ID=-100xxxxxxxxxx
